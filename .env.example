# ============================================
# SLINGSHOT ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# Add same vars to Vercel Project Settings
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (Test mode for dev, Live mode for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (used in metadata, OG tags, redirects)
NEXT_PUBLIC_APP_URL=https://slingshot.my
# For local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slingshot plan price IDs (from Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_DFY_ONETIME=price_xxx

# WhatsApp Business API (optional, can add later)
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
